@{
    ViewData["Title"] = "Alien Space";
    ViewData["BodyClass"] = "home-space";
}

<section class="space-landing" aria-label="Alien space escape room">
    <div class="star-field star-field-one"></div>
    <div class="star-field star-field-two"></div>
    <div class="planet planet-outer"></div>
    <div class="planet planet-inner"></div>

    <div class="ufo" aria-hidden="true">
        <div class="ufo-glow"></div>
        <div class="ufo-dome"></div>
        <div class="ufo-body"></div>
        <div class="ufo-lights">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </div>

    <div class="alien-orbit" aria-hidden="true">
        <div class="alien-head">
            <span class="alien-eye alien-eye-left"></span>
            <span class="alien-eye alien-eye-right"></span>
            <span class="alien-mouth"></span>
        </div>
    </div>

    <div class="space-content">
        <p class="space-kicker">Signal upptäckt</p>
        <h1>Escape room</h1>
        <p class="space-copy">
            Mörk rymd, främmande spår och en dörr som bara öppnas om du löser mysteriet.
        </p>
        <div class="space-actions">
            <a asp-action="Room1" class="space-start-btn">
                Starta
            </a>
            <button class="space-instructions-btn" type="button" data-bs-toggle="modal"
                    data-bs-target="#instructionsModal">
                Instruktioner
            </button>
        </div>
    </div>
</section>

<div class="modal fade" id="instructionsModal" tabindex="-1" aria-labelledby="instructionsTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content space-instructions">
            <div class="modal-header">
                <h2 class="modal-title" id="instructionsTitle">Så här spelar du:</h2>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <ol>
                    <li>Tryck Starta → timern börjar direkt.</li>
                    <li>Du har 5 rum att klara.</li>
                    <li>Leta efter ledtrådar i rummet.</li>
                    <li>Lös pusslet för att öppna nästa dörr.</li>
                    <li>Om du använder en hint läggs 10–30 sekunder till, beroende på vilket rum du är i
                    </li>
                </ol>
            </div>
        </div>
    </div>
</div>
